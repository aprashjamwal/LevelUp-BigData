    "# Step 2: Map region abbreviations/variants to canonical values\n",
    "region_map = {\n",
    "    \"NA\":             \"North America\",\n",
    "    \"north america\":  \"North America\",\n",
    "    \"EU\":             \"Europe\",\n",
    "    \"europe\":         \"Europe\",\n",
    "    \"APAC\":           \"Asia Pacific\",\n",
    "    \"asia pacific\":   \"Asia Pacific\",\n",
    "    \"LATAM\":          \"Latin America\",\n",
    "    \"latin america\":  \"Latin America\",\n",
    "}\n",
    "\n",
    "# Build a CASE WHEN expression from the dictionary\n",
    "region_expr = F.col(\"region\")\n",
    "for raw_val, canonical in region_map.items():\n",
    "    region_expr = F.when(F.col(\"region\") == raw_val, canonical).otherwise(region_expr)\n",
    "\n",
    "# Apply all cleaning steps in a single chain\n",
    "players_silver = (\n",
    "    players_raw\n",
    "    .withColumn(\"region\",       region_expr)\n",
    "    .withColumn(\"account_type\", F.initcap(F.lower(F.col(\"account_type\"))))  # normalize casing\n",
    "    .withColumn(\"age\",          F.col(\"age\").cast(IntegerType()))            # string → int\n",
    "    .withColumn(\"join_date\",    F.to_date(F.col(\"join_date\"), \"yyyy-MM-dd\")) # string → date\n",
    "    .filter(F.col(\"email\").isNotNull())                                       # drop null emails\n",
    ")\n",
    "\n",
    "before = players_raw.count()\n",
    "after  = players_silver.count()\n",
    "print(f\"players: {before} → {after} rows  (dropped {before - after} null-email records)\")\n",
    "\n",
    "null_report(players_silver, \"players_silver\")\n",
    "display(players_silver.limit(10))"
   ]
