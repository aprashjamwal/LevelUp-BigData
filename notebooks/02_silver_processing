    "purchases_silver = (\n",
    "    purchases_raw\n",
    "    .withColumn(\"category\",      F.initcap(F.lower(F.col(\"category\"))))\n",
    "    .withColumn(\"purchase_date\", F.to_date(F.col(\"purchase_date\"), \"yyyy-MM-dd\"))\n",
    "    # Remove invalid transactions with zero or negative spending\n",
    "    .filter(F.col(\"amount_spent\") > 0)\n",
    ")\n",
    "\n",
    "before = purchases_raw.count()\n",
    "after  = purchases_silver.count()\n",
    "print(f\"purchases: {before} → {after} rows  (dropped {before - after} negative-amount records)\")\n",
    "\n",
    "print(\"\\nDistinct category values (silver):\")\n",
    "display(purchases_silver.groupBy(\"category\").count().orderBy(\"category\"))\n",
    "\n",
    "null_report(purchases_silver, \"purchases_silver\")\n",
    "display(purchases_silver.limit(10))"
