    "# Count invalid records before cleaning\n",
    "invalid_duration = sessions_raw.filter(F.col(\"duration_minutes\") <= 0).count()\n",
    "null_scores      = sessions_raw.filter(F.col(\"score\").isNull()).count()\n",
    "log.info(\"Sessions: %d rows with invalid duration, %d rows with null score\",\n",
    "         invalid_duration, null_scores)\n",
    "\n",
    "sessions_silver = (\n",
    "    sessions_raw\n",
    "    .withColumn(\"session_date\",     F.to_date(F.col(\"session_date\"), \"yyyy-MM-dd\"))  # cast to date\n",
    "    .withColumn(\"duration_minutes\", F.round(F.col(\"duration_minutes\"), 2))\n",
    "     # drop invalid sesions with no positive durations\n",
    "    .filter(F.col(\"duration_minutes\") > 0) \n",
    "    # Replace null scores with 0                                          \n",
    "    .withColumn(\"score\", F.coalesce(F.col(\"score\"), F.lit(0)))                        # impute nulls\n",
    ")\n",
    "\n",
    "before = sessions_raw.count()\n",
    "after  = sessions_silver.count()\n",
    "print(f\"game_sessions: {before} → {after} rows  (dropped {before - after} invalid-duration records)\")\n",
    "\n",
    "null_report(sessions_silver, \"game_sessions_silver\")\n",
    "display(sessions_silver.limit(10))"
   ]
