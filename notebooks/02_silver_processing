    "# Count negative amounts before cleaning\n",
    "negative_amounts = purchases_raw.filter(F.col(\"amount_spent\") <= 0).count()\n",
    "log.info(\"Purchases: %d rows with invalid (negative) amount_spent\", negative_amounts)\n",
